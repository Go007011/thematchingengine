{
  "name": "@matchingengine/preview",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm run clean && pnpm run build-assets && pnpm run html",
    "build-assets": "concurrently \"pnpm run css\" \"pnpm run js\"",
    "dev": "pnpm run clean && pnpm run watch",
    "watch": "concurrently \"pnpm run watch-html\" \"pnpm run watch-css\" \"pnpm run watch-js\"",
    "watch-html": "cross-env NODE_ENV=development eleventy --serve --port=3000 --watch --incremental",
    "watch-js": "nodemon --watch js/ --ext ts --exec \"pnpm run js\"",
    "watch-css": "nodemon --watch scss/ --ext scss --exec \"pnpm run css\"",
    "css": "pnpm run css-build && pnpm run css-prefix && pnpm run css-minify",
    "css-build": "sass scss/:dist/preview/css/ --no-source-map --load-path=node_modules",
    "css-prefix": "postcss --config .build/postcss.config.mjs --replace \"dist/preview/css/*.css\" \"!dist/preview/css/*.min.css\"",
    "css-minify": "cleancss -O1 --format breakWith=lf --with-rebase --source-map --source-map-inline-sources --output dist/preview/css/ --batch --batch-suffix \".min\" \"dist/preview/css/*.css\" \"!dist/preview/css/*.min.css\"",
    "js": "pnpm run js-build && pnpm run js-build-min",
    "js-build": "vite build --config .build/vite.config.mts",
    "js-build-min": "terser dist/preview/js/dashboard.js --module --compress --mangle --comments false --source-map \"content=dist/preview/js/dashboard.js.map,filename=dist/preview/js/dashboard.min.js.map,url=dashboard.min.js.map\" -o dist/preview/js/dashboard.min.js",
    "clean": "shx rm -rf dist demo",
    "html": "pnpm run html-build && pnpm run html-prettify && pnpm run html-remove-prettier-ignore",
    "html-build": "eleventy",
    "html-prettify": "prettier --write \"dist/**/*.html\"",
    "html-remove-prettier-ignore": "node .build/remove-prettier-ignore.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.0"
  },
  "dependencies": {
    "@tabler/core": "workspace:*"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "printWidth": 120
  }
}
